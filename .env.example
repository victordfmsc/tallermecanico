# ============================================================
# ShopFlow — Variables de Entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================================

# ── BASE DE DATOS ────────────────────────────────────────────
# PostgreSQL (Supabase recomendado: supabase.com)
DATABASE_URL="postgresql://usuario:contraseña@host:5432/shopflow"

# ── NEXTAUTH v5 ──────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-aqui-minimo-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Google (opcional — para login con Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── STRIPE (pagos y suscripciones) ───────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# IDs de precio de los planes (crear en Stripe Dashboard)
STRIPE_PRICE_STARTER="price_..."    # 29€/mes — hasta 2 técnicos
STRIPE_PRICE_PRO="price_..."        # 59€/mes — hasta 8 técnicos
STRIPE_PRICE_ENTERPRISE="price_..." # 99€/mes — ilimitado

# ── EMAIL TRANSACCIONAL (Resend) ──────────────────────────────
# Crea cuenta en resend.com (plan gratuito: 3000 emails/mes)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@tudominio.com"

# ── RATE LIMITING (Upstash Redis) ────────────────────────────
# Crea base de datos Redis en upstash.com (plan gratuito disponible)
UPSTASH_REDIS_REST_URL="https://....upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# ── SMS (Twilio) — OPCIONAL ───────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── SUPABASE STORAGE (fotos DVI) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── ANALYTICS (PostHog) — OPCIONAL ───────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ── ERROR TRACKING (Sentry) — OPCIONAL ───────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG="shopflow"
SENTRY_PROJECT="shop-management"
SENTRY_AUTH_TOKEN=""

# ── SUPER ADMIN ───────────────────────────────────────────────
# Email que se promoverá a superadmin en el primer deploy
SUPER_ADMIN_EMAIL="victordfmsc@gmail.com"
