// ShopFlow — Prisma Schema
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                     String    @id @default(cuid())
  name                   String
  address                String?
  phone                  String?
  nif                    String?
  logo                   String?
  subscriptionStatus     String    @default("FREE_TRIAL") // FREE_TRIAL | ACTIVE | PAST_DUE | CANCELLED
  subscriptionPlan       String    @default("STARTER")    // STARTER | PROFESSIONAL | ENTERPRISE
  trialEndsAt            DateTime?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  onboardingStep         Int       @default(1)
  smsCredits            Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  users             User[]
  technicians       Technician[]
  customers         Customer[]
  vehicles          Vehicle[]
  workOrders        WorkOrder[]
  estimates         Estimate[]
  invoices          Invoice[]
  inspections       Inspection[]
  inventoryItems    InventoryItem[]
  messages          Message[]
  marketingCampaigns MarketingCampaign[]
  purchaseOrders    PurchaseOrder[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("TECHNICIAN") // OWNER | ADMIN | TECHNICIAN | RECEPTIONIST
  isSuperAdmin  Boolean   @default(false)
  shopId        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shop     Shop?     @relation(fields: [shopId], references: [id])
  accounts Account[]
  sessions Session[]
}

model Technician {
  id           String   @id @default(cuid())
  shopId       String
  name         String
  specialty    String
  avatar       String?
  efficiency   Float    @default(0)
  status       String   @default("active") // active | inactive
  activeJobs   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop       Shop        @relation(fields: [shopId], references: [id])
  workOrders WorkOrder[]
}

model Customer {
  id          String   @id @default(cuid())
  shopId      String
  name        String
  email       String   @unique
  phone       String?
  address     String?
  totalVisits Int      @default(0)
  totalSpent  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop       Shop        @relation(fields: [shopId], references: [id])
  vehicles   Vehicle[]
  workOrders WorkOrder[]
  estimates  Estimate[]
  invoices   Invoice[]
  messages   Message[]
}

model Vehicle {
  id           String   @id @default(cuid())
  shopId       String
  customerId   String
  make         String
  model        String
  year         Int
  vin          String?  @unique
  licensePlate String?
  mileage      Int      @default(0)
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop       Shop        @relation(fields: [shopId], references: [id])
  customer   Customer    @relation(fields: [customerId], references: [id])
  workOrders WorkOrder[]
  estimates  Estimate[]
}

model WorkOrder {
  id           String   @id @default(cuid())
  shopId       String
  vehicleId    String
  customerId   String
  technicianId String?
  status       String   @default("pending") // pending | diagnosis | in_repair | ready | delivered
  services     Json     @default("[]")
  totalAmount  Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop       Shop        @relation(fields: [shopId], references: [id])
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id])
  customer   Customer    @relation(fields: [customerId], references: [id])
  technician Technician? @relation(fields: [technicianId], references: [id])
  inspections Inspection[]
  invoices    Invoice[]
  estimates   Estimate[]
}

model Estimate {
  id          String   @id @default(cuid())
  shopId      String
  customerId  String
  vehicleId   String
  workOrderId String?
  status      String   @default("draft") // draft | sent | approved | rejected
  lines       Json     @default("[]")
  totalAmount Float    @default(0)
  sentAt      DateTime?
  publicToken String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop      Shop       @relation(fields: [shopId], references: [id])
  customer  Customer   @relation(fields: [customerId], references: [id])
  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id])
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])
}

model Invoice {
  id          String    @id @default(cuid())
  shopId      String
  workOrderId String?
  customerId  String
  status      String    @default("pending") // pending | paid | overdue
  totalAmount Float
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shop      Shop       @relation(fields: [shopId], references: [id])
  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])
  customer  Customer   @relation(fields: [customerId], references: [id])
}

model Inspection {
  id          String    @id @default(cuid())
  shopId      String
  workOrderId String
  sections    Json      @default("[]")
  overallStatus String  @default("good") // good | attention | urgent
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shop      Shop      @relation(fields: [shopId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
}

model InventoryItem {
  id          String   @id @default(cuid())
  shopId      String
  name        String
  sku         String   @unique
  category    String
  quantity    Int      @default(0)
  minQuantity Int      @default(5)
  costPrice   Float
  salePrice   Float
  supplier    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id        String   @id @default(cuid())
  shopId    String
  itemId    String
  quantity  Int
  supplier  String
  status    String   @default("pending") // pending | received | cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop          @relation(fields: [shopId], references: [id])
  item InventoryItem @relation(fields: [itemId], references: [id])
}

model Message {
  id         String    @id @default(cuid())
  shopId     String
  customerId String
  direction  String    // inbound | outbound
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  shop     Shop     @relation(fields: [shopId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

model MarketingCampaign {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  type      String   // sms | email | review | reminder
  status    String   @default("draft") // draft | active | completed
  sent      Int      @default(0)
  opened    Int      @default(0)
  clicked   Int      @default(0)
  content   String?
  segment   Json?    // { criteria: 'all' | 'last_visit' | 'service_type', value?: any }
  scheduledFor DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

