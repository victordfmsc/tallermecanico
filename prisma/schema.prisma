// ShopFlow — Prisma Schema
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Technician {
  id         String   @id @default(cuid())
  name       String
  specialty  String
  avatar     String?
  efficiency Float    @default(0)
  status     String   @default("active") // active | inactive
  activeJobs Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workOrders WorkOrder[]
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  address     String?
  totalVisits Int      @default(0)
  totalSpent  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicles   Vehicle[]
  workOrders WorkOrder[]
  estimates  Estimate[]
  invoices   Invoice[]
  messages   Message[]
}

model Vehicle {
  id           String   @id @default(cuid())
  customerId   String
  make         String
  model        String
  year         Int
  vin          String?  @unique
  licensePlate String?
  mileage      Int      @default(0)
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id])
  workOrders WorkOrder[]
  estimates  Estimate[]
}

model WorkOrder {
  id           String   @id @default(cuid())
  vehicleId    String
  customerId   String
  technicianId String?
  status       String   @default("pending") // pending | diagnosis | in_repair | ready | delivered
  services     Json     @default("[]")
  totalAmount  Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vehicle      Vehicle     @relation(fields: [vehicleId], references: [id])
  customer     Customer    @relation(fields: [customerId], references: [id])
  technician   Technician? @relation(fields: [technicianId], references: [id])
  inspections  Inspection[]
  invoices     Invoice[]
}

model Estimate {
  id          String   @id @default(cuid())
  customerId  String
  vehicleId   String
  status      String   @default("draft") // draft | sent | approved | rejected
  lines       Json     @default("[]")
  totalAmount Float    @default(0)
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Invoice {
  id          String    @id @default(cuid())
  workOrderId String?
  customerId  String
  status      String    @default("pending") // pending | paid | overdue
  totalAmount Float
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workOrder WorkOrder? @relation(fields: [workOrderId], references: [id])
  customer  Customer   @relation(fields: [customerId], references: [id])
}

model Inspection {
  id          String    @id @default(cuid())
  workOrderId String
  sections    Json      @default("[]")
  overallStatus String  @default("good") // good | attention | urgent
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  category    String
  quantity    Int      @default(0)
  minQuantity Int      @default(5)
  costPrice   Float
  salePrice   Float
  supplier    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id         String    @id @default(cuid())
  customerId String
  direction  String    // inbound | outbound
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model MarketingCampaign {
  id        String   @id @default(cuid())
  name      String
  type      String   // sms | email | review | reminder
  status    String   @default("draft") // draft | active | completed
  sent      Int      @default(0)
  opened    Int      @default(0)
  clicked   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
